# Copy to .env and fill in. Loaded automatically by the advaita-bench CLI;
# real environment variables take precedence. .env is gitignored — never
# commit keys.

# Direct providers (first-party credits)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# OpenRouter — Grok, DeepSeek, Qwen, GLM, Kimi, Llama, Mistral, etc.
# NOTE: these calls spend real OpenRouter balance; per-run cost is reported
# in the run manifest.
OPENROUTER_API_KEY=
