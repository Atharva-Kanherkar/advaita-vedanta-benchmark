{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://advaita-bench.dev/schemas/task/v1",
  "title": "AdvaitaBench Task",
  "type": "object",
  "required": ["id", "family", "prompt", "rubric_dimensions"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z]{2,4}-[0-9]{3}$" },
    "family": {
      "type": "string",
      "enum": [
        "concept_precision",
        "level_of_reality",
        "school_discrimination",
        "text_grounded",
        "misconception_repair",
        "consistency_adversarial",
        "open_elicitation",
        "sustained_dialectic"
      ]
    },
    "prompt": { "type": "string", "minLength": 10 },
    "turns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "content"],
        "properties": {
          "role": { "enum": ["user", "assistant"] },
          "content": { "type": "string" }
        }
      },
      "description": "Prior conversation before final user prompt (multi-turn tasks)"
    },
    "passage": {
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "source": { "type": "string" },
        "tier": { "enum": ["A", "B", "C"] }
      }
    },
    "variant_group_id": { "type": "string" },
    "gold_doctrine_key": { "type": "string" },
    "target_school": { "type": "string", "default": "advaita" },
    "contrast_school": { "type": "string" },
    "language": { "enum": ["en", "sa", "mixed"], "default": "en" },
    "rubric_dimensions": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "dimension_weights": {
      "type": "object",
      "additionalProperties": { "type": "number", "minimum": 0, "maximum": 1 }
    },
    "gold_points": { "type": "array", "items": { "type": "string" } },
    "required_distinctions": { "type": "array", "items": { "type": "string" } },
    "forbidden_claims": { "type": "array", "items": { "type": "string" } },
    "reference_answer": {
      "type": "string",
      "description": "Full prose answer the judge grades against (verification, not generation)"
    },
    "failure_tags_watch": { "type": "array", "items": { "type": "string" } },
    "tags": { "type": "array", "items": { "type": "string" } },
    "difficulty": { "enum": ["pilot", "standard", "hard"], "default": "pilot" },
    "provenance": {
      "enum": ["canonical", "paraphrased", "novel"],
      "default": "canonical",
      "description": "Relation to widely-available training data; reported stratified as a memorization control"
    }
  }
}
